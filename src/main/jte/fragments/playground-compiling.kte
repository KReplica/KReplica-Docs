@param jobId: String
@param jobsAhead: Int

<div hx-ext="sse" sse-connect="/playground/status/${jobId}" sse-swap="message">
    <div class="placeholder-text">
        @if(jobsAhead > 0)
            <p>You are number ${jobsAhead + 1} in the queue.</p>
        @else
            <p>Compiling... your request is being processed.</p>
        @endif
    </div>
</div>